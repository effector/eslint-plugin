{
  "name": "eslint-plugin-effector",
  "version": "0.19.0",
  "description": "Enforcing best practices for Effector",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "effector"
  ],
  "homepage": "https://eslint.effector.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/effector/eslint-plugin.git"
  },
  "license": "MIT",
  "author": "Igor Kamyshev <igor@kamyshev.me>",
  "contributors": [
    {
      "name": "Mikhail Kireev",
      "url": "https://github.com/kireevmp"
    }
  ],
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "lint": "eslint",
    "prepack": "pnpm build",
    "test": "vitest run"
  },
  "dependencies": {
    "@typescript-eslint/type-utils": "^8.59.3",
    "@typescript-eslint/utils": "^8.59.3",
    "esquery": "^1.7.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/esquery": "^1.5.4",
    "@types/estree": "^1.0.9",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@typescript-eslint/rule-tester": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.8",
    "effector": "^23.4.4",
    "effector-factorio": "^1.3.0",
    "effector-react": "^23.3.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "prettier-plugin-embed": "^0.5.1",
    "tsdown": "0.22.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0",
    "typescript": ">=5.0.0"
  },
  "packageManager": "pnpm@10.34.3+sha512.f2c531b08829d7be7f03c90addc266615f9c5477463e4bf1d275cb263ce9ea57cf0d5599110d94649a9bb3fed9f0b5efcea74a7016b61532a24cb9ad87860c1d",
  "engines": {
    "node": ">=21.1.0"
  }
}
