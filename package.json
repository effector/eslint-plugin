{
  "name": "eslint-plugin-effector",
  "version": "0.18.0",
  "description": "Enforcing best practices for Effector",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "effector"
  ],
  "homepage": "https://eslint.effector.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/effector/eslint-plugin"
  },
  "license": "MIT",
  "author": "Igor Kamyshev <igor@kamyshev.me>",
  "contributors": [
    {
      "name": "Mikhail Kireev",
      "url": "https://github.com/kireevmp"
    }
  ],
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "lint": "eslint",
    "prepack": "pnpm build",
    "test": "vitest run"
  },
  "dependencies": {
    "@typescript-eslint/type-utils": "^8.59.3",
    "@typescript-eslint/utils": "^8.59.3",
    "esquery": "^1.7.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/esquery": "^1.5.4",
    "@types/estree": "^1.0.9",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@typescript-eslint/rule-tester": "^8.59.3",
    "@vitest/coverage-v8": "^4.1.6",
    "effector": "^23.4.4",
    "effector-factorio": "^1.3.0",
    "effector-react": "^23.3.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.3",
    "prettier-plugin-embed": "^0.5.1",
    "tsdown": "0.21.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitepress": "2.0.0-alpha.15",
    "vitest": "^4.1.6"
  },
  "peerDependencies": {
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0",
    "typescript": ">=5.0.0"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "engines": {
    "node": "^20.9.0 || >=21.1.0"
  }
}
